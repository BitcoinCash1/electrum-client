{
	"name": "@bitcoincash/electrum-client",
	"version": "1.2.0",
	"description": "Electrum protocol client for Node.js supporting Fulcrum",
	"author": "Melroy van den Berg <melroy@melroy.org>",
	"license": "MIT",
	"type": "module",
	"exports": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"check-types": "tsc --noEmit",
		"lint": "npx --node-options='--experimental-strip-types' eslint src --flag unstable_native_nodejs_ts_config",
		"fix": "npx --node-options='--experimental-strip-types' eslint src --fix --flag unstable_native_nodejs_ts_config",
		"format": "prettier --check \"**/*.{js,ts}\"",
		"format:fix": "prettier --write \"**/*.{js,ts}\""
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"eslint": "^10.2.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.5",
		"globals": "^17.5.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.1"
	},
	"repository": {
		"type": "git",
		"url": "git://github.com/BitcoinCash1/electrum-client.git"
	},
	"bugs": {
		"url": "https://github.com/BitcoinCash1/electrum-client/issues"
	},
	"keywords": [
		"bitcoin",
		"cash",
		"bitcoin cash",
		"electrum",
		"electrumx",
		"fulcrum"
	],
	"engines": {
		"node": ">=14"
	},
	"contributors": [
		{
			"name": "Yuki Akiyama"
		},
		{
			"name": "7kharov"
		},
		{
			"name": "overtorment"
		},
		{
			"name": "janoside"
		},
		{
			"name": "softsimon"
		}
	]
}
