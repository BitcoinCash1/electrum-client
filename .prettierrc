{
  "tabWidth": 2,
  "printWidth": 120,
  "useTabs": false,
  "trailingComma": "none",
  "semi": false,
  "singleQuote": true,
  "bracketSpacing": true,
  "arrowParens": "always",
  "insertPragma": false,
  "bracketSameLine": true,
  "htmlWhitespaceSensitivity": "css",
  "singleAttributePerLine": false,
  "proseWrap": "always"
}
